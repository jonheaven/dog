#!/usr/bin/env bash

set -euxo pipefail

die() {
  echo "$1"
  exit 1
}

new=/var/lib/dog/index.redb.new
current=/var/lib/dog/index.redb
old=/var/lib/dog/index.redb.old

[[ -f $new ]] || die "new index missing: $new"
[[ -f $current ]] || die "old index missing: $current"
[[ ! -f $old ]] || die "backup index already exists: $old"

systemctl stop dog

chown dog:dog $new

mv $current $old
mv $new $current

systemctl restart dog
