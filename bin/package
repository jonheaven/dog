#!/usr/bin/env bash

set -euxo pipefail

VERSION=${REF#"refs/tags/"}
DIST=`pwd`/dist

echo "Packaging dog $VERSION for $TARGET..."

test -f Cargo.lock || cargo generate-lockfile

echo "Building dog..."
RUSTFLAGS="--deny warnings $TARGET_RUSTFLAGS" \
  cargo build --bin dog --target $TARGET --release
EXECUTABLE=target/$TARGET/release/dog

if [[ $OS == windows-latest ]]; then
  EXECUTABLE=$EXECUTABLE.exe
fi

echo "Copying release files..."
mkdir -p dist/dog-$VERSION
cp \
  $EXECUTABLE \
  Cargo.lock \
  Cargo.toml \
  LICENSE \
  README.md \
  $DIST/dog-$VERSION

cd $DIST
echo "Creating release archive..."
case $OS in
  ubuntu-latest | macos-latest)
    ARCHIVE=$DIST/dog-$VERSION-$TARGET.tar.gz
    tar czf $ARCHIVE *
    if [[ -n "${GITHUB_OUTPUT+x}" ]]; then
      echo archive=$ARCHIVE >> $GITHUB_OUTPUT
    fi
    ;;
  windows-latest)
    ARCHIVE=$DIST/dog-$VERSION-$TARGET.zip
    7z a $ARCHIVE *
    if [[ -n "${GITHUB_OUTPUT+x}" ]]; then
      echo archive=`pwd -W`/dog-$VERSION-$TARGET.zip >> $GITHUB_OUTPUT
    fi
    ;;
esac
